# ── Better Auth ───────────────────────────────────────────────────────────────
# Public origin of THIS gateway (the OAuth issuer + MCP endpoint host).
BETTER_AUTH_URL=https://mcp.quantakrypto.com
# 32+ byte random secret: `openssl rand -base64 32`
BETTER_AUTH_SECRET=

# ── Database (your own Postgres) ──────────────────────────────────────────────
DATABASE_URL=postgres://quantakrypto:CHANGE_ME@localhost:5432/quantakrypto_mcp

# ── Social sign-in ────────────────────────────────────────────────────────────
# Google OAuth client (Google Cloud Console → Credentials → OAuth client ID).
# Authorized redirect URI: https://mcp.quantakrypto.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GitHub OAuth app (github.com/settings/developers).
# Callback URL: https://mcp.quantakrypto.com/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Email (Resend) — verification + magic links ───────────────────────────────
RESEND_API_KEY=
# Must be a verified sender domain in Resend.
EMAIL_FROM="quantakrypto <no-reply@quantakrypto.com>"
